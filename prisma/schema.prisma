// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OgiSubmission {
  id          String   @id @default(cuid())
  name        String
  role        String
  contact     String   // email or phone, whatever was entered
  email       String?  // explicitly validated email if available, used for result delivery
  score       Int
  band        String
  answersJson String   // JSON.stringify of the raw answers object
  createdAt   DateTime @default(now())

  @@index([createdAt]) // speed up "newest first" queries
  @@index([name, contact]) // speed up duplicate-check queries
}
