# ── Google Sheets logging ───────────────────────────────────────────────────
# Service account creds for appending OGI submissions to the shared
# "AVYSTRA OGI Submissions" sheet. All three must be set to enable sheet
# logging; if any is missing, sheet append is skipped silently.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEET_ID=
